{%- comment -%}
  DEPRECATED (manual theme edit required).
  This snippet is kept for reference, but the recommended setup is Theme App Extension App Embed.

  If you still use it, it now loads widget assets from the app domain (Render) and reads metafields using `.value`.
{%- endcomment -%}

{%- assign sp_status = app.metafields.sheet_pulse.status.value | default: 'active' -%}

{%- if sp_status == 'active' -%}
  {%- assign sp_app_url = app.metafields.sheet_pulse.app_url.value | default: 'https://sheetpulse.onrender.com' -%}
  {%- assign sp_widget_js = sp_app_url | append: '/widget/widget.js' -%}
  {%- assign sp_widget_css = sp_app_url | append: '/widget/widget.css' -%}
  {%- assign sp_cache_bust = 'now' | date: '%s' -%}

  <script>
    window.SheetPulse = {
      questions: {{ app.metafields.sheet_pulse.q_json.value | default: '[]' }},
      googleUrl: {{ app.metafields.sheet_pulse.g_url.value | default: '' | json }},
      triggerType: {{ app.metafields.sheet_pulse.t_type.value | default: 'timer' | json }},
      tVal: {{ app.metafields.sheet_pulse.t_val.value | default: '3' | json }},
      targetDevice: {{ app.metafields.sheet_pulse.t_dev.value | default: 'all' | json }},
      accentColor: {{ app.metafields.sheet_pulse.a_col.value | default: '000000' | json }},
      lang: {{ app.metafields.sheet_pulse.lang.value | default: 'en' | json }},
      status: {{ app.metafields.sheet_pulse.status.value | default: 'active' | json }},
      surveyVersion: {{ app.metafields.sheet_pulse.survey_version.value | default: '' | json }},
      widgetPosition: {{ app.metafields.sheet_pulse.w_pos.value | default: 'right' | json }},
      appUrl: {{ sp_app_url | json }}
    };

    console.log("✅ SheetPulse initialized:", window.SheetPulse);
  </script>

  <link rel="stylesheet" href="{{ sp_widget_css }}?v={{ sp_cache_bust }}">
  <script src="{{ sp_widget_js }}?v={{ sp_cache_bust }}" defer></script>
{%- endif -%}