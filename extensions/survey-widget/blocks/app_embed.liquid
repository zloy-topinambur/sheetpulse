<div id="sheetpulse-widget-root" 
     data-questions='{{ app.metafields.sheet_pulse.q_json | default: '[]' | json }}'
     data-google-url="{{ app.metafields.sheet_pulse.g_url | default: '' }}"
     data-trigger-type="{{ app.metafields.sheet_pulse.t_type | default: 'timer' }}"
     data-trigger-value="{{ app.metafields.sheet_pulse.t_val | default: '3' }}"
     data-target-device="{{ app.metafields.sheet_pulse.t_dev | default: 'all' }}"
     data-accent-color="{{ app.metafields.sheet_pulse.a_col | default: '000000' }}"
     data-lang="{{ app.metafields.sheet_pulse.lang | default: 'en' }}"
     data-status="{{ app.metafields.sheet_pulse.status | default: 'active' }}"
     data-survey-version="{{ app.metafields.sheet_pulse.survey_version | default: '' }}"
     data-widget-position="{{ app.metafields.sheet_pulse.w_pos | default: 'right' }}">
</div>
<script src="{{ 'widget.js' | asset_url }}" defer></script>
<link rel="stylesheet" href="{{ 'widget.css' | asset_url }}">
{% schema %}
{ "name": "SheetPulse Widget", "target": "body", "settings": [] }
{% endschema %}
