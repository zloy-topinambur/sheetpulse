<div id="sheetpulse-widget-root"></div>
<script>
  console.log("📋 SheetPulse metafields from Liquid:", {
    q_json: {{ app.metafields.sheet_pulse.q_json | default: '[]' | json }},
    g_url: "{{ app.metafields.sheet_pulse.g_url | default: '' }}",
    t_type: "{{ app.metafields.sheet_pulse.t_type | default: 'timer' }}",
    t_val: "{{ app.metafields.sheet_pulse.t_val | default: '3' }}",
    t_dev: "{{ app.metafields.sheet_pulse.t_dev | default: 'all' }}",
    a_col: "{{ app.metafields.sheet_pulse.a_col | default: '000000' }}",
    lang: "{{ app.metafields.sheet_pulse.lang | default: 'en' }}",
    status: "{{ app.metafields.sheet_pulse.status | default: 'active' }}",
    survey_version: "{{ app.metafields.sheet_pulse.survey_version | default: '' }}",
    w_pos: "{{ app.metafields.sheet_pulse.w_pos | default: 'right' }}"
  });

  window.SheetPulse = {
    questions: {{ app.metafields.sheet_pulse.q_json | default: '[]' }},
    googleUrl: "{{ app.metafields.sheet_pulse.g_url | default: '' }}",
    triggerType: "{{ app.metafields.sheet_pulse.t_type | default: 'timer' }}",
    tVal: "{{ app.metafields.sheet_pulse.t_val | default: '3' }}",
    targetDevice: "{{ app.metafields.sheet_pulse.t_dev | default: 'all' }}",
    accentColor: "{{ app.metafields.sheet_pulse.a_col | default: '000000' }}",
    lang: "{{ app.metafields.sheet_pulse.lang | default: 'en' }}",
    status: "{{ app.metafields.sheet_pulse.status | default: 'active' }}",
    surveyVersion: "{{ app.metafields.sheet_pulse.survey_version | default: '' }}",
    widgetPosition: "{{ app.metafields.sheet_pulse.w_pos | default: 'right' }}"
  };

  console.log("✅ SheetPulse initialized:", window.SheetPulse);
</script>
<script>
  (function() {
    const { questions, googleUrl, triggerType, tVal, targetDevice, accentColor, lang, status } = window.SheetPulse;
    
    // FIX: СТРОГАЯ ПРОВЕРКА СТАТУСА. Если stopped - выход.
    if (status !== 'active') return;
    if (!questions?.length || !googleUrl) return;

    const isPreview = window.location.search.includes('preview=1');
    const surveyId = questions[0]?.id || 'default';
    const doneKey = `sp_done_${surveyId}`;
    const closedKey = `sp_closed_${surveyId}`;

    // Проверка: пройден ли опрос или закрыт
    if (!isPreview && (localStorage.getItem(doneKey) || localStorage.getItem(closedKey))) return;

    const isMobile = /iPhone|iPad|iPod|Android/i.test(navigator.userAgent);
    const currentDevice = isMobile ? 'mobile' : 'desktop';
    if (targetDevice !== 'all' && targetDevice !== currentDevice) return;

    let respondentId = sessionStorage.getItem('sp_uid') || 'SP-' + Math.random().toString(36).substr(2, 9).toUpperCase();
    sessionStorage.setItem('sp_uid', respondentId);

    const i18n = {
      en: { next: "Next", back: "Back", finish: "Finish", skip: "Not sure", thanks: "You're awesome! Thanks for helping us grow. 🚀", other: "Other..." },
      es: { next: "Siguiente", back: "Atrás", finish: "Finalizar", skip: "No lo sé", thanks: "¡Eres genial! Gracias por ayudarnos. 🚀", other: "Otro..." },
      de: { next: "Weiter", back: "Zurück", finish: "Beenden", skip: "Nicht sicher", thanks: "Danke für deine Hilfe! 🚀", other: "Anderes..." },
      fr: { next: "Suivant", back: "Retour", finish: "Terminer", skip: "Pas sûr", thanks: "Merci de nous aider! 🚀", other: "Autre..." },
      pt: { next: "Próximo", back: "Voltar", finish: "Finalizar", skip: "Não sei", thanks: "Obrigado por nos ajudar! 🚀", other: "Outro..." }
    }[lang || 'en'];

    let currentStep = 0;
    let answers = {};
    let selected = []; 
    
    // Цветовая схема
    let theme = (accentColor && accentColor.startsWith('#')) ? accentColor : '#' + (accentColor || '000');
    const isWhite = theme.toLowerCase() === '#ffffff' || theme.toLowerCase() === '#fff';
    const btnTxt = isWhite ? '#000000' : '#ffffff';
    const btnBorder = isWhite ? '1px solid #ccc' : 'none';

    const show = () => document.getElementById('sp-widget')?.classList.remove('sp-hidden');

    // ФУНКЦИЯ: Проверяет, можно ли идти дальше, и обновляет состояние кнопки
    const updateNextButton = () => {
      const btn = document.getElementById('sp-next');
      if(!btn) return;
      
      let hasAnswer = selected.length > 0;
      
      // Текст
      const textInput = document.getElementById('sp-i');
      if (textInput && textInput.value.trim().length > 0) hasAnswer = true;
      
      // Поле "Другое"
      const otherInput = document.getElementById('sp-ot-i');
      if (otherInput && otherInput.value.trim().length > 0) hasAnswer = true;

      if (hasAnswer) {
        btn.disabled = false;
        btn.style.opacity = '1';
        btn.style.cursor = 'pointer';
      } else {
        btn.disabled = true;
        btn.style.opacity = '0.5';
        btn.style.cursor = 'not-allowed';
      }
    };

    const render = () => {
      const q = questions[currentStep];
      const container = document.getElementById('sp-card');
      if (!container) return;
      const isLast = currentStep === questions.length - 1;
      selected = [];
      
      let html = `<button id="sp-close">×</button>
                  <div class="sp-prog" style="color:${theme}">STEP ${currentStep+1}/${questions.length}</div>
                  <p class="sp-q">${q.label}</p>
                  <div class="sp-body">`;

      if (q.type.includes('emoji')) {
        const ems = q.type === 'emoji' ? ['😞','😐','🤩'] : ['😡','😟','😐','🙂','😍'];
        // CSS класс sp-ems-5 управляет размером шрифта
        html += `<div class="sp-ems ${ems.length > 3 ? 'sp-ems-5' : ''}">${ems.map(e => `<button class="sp-e-btn" data-val="${e}">${e}</button>`).join('')}</div>`;
      } else if (q.type === 'radio' || q.type === 'checkbox') {
        const opts = q.options ? q.options.split(',').map(o => o.trim()) : [];
        html += `<div class="sp-list">${opts.map(o => `<button class="sp-o" data-val="${o}">${q.type==='checkbox'?'<span class="sp-c"></span> ':''}${o}</button>`).join('')}</div>`;
        if (q.hasOther) html += `<input type="text" id="sp-ot-i" placeholder="${i18n.other}" class="sp-input">`;
        if (q.notSure) html += `<button class="sp-o sp-skip" data-val="Skip">${i18n.skip}</button>`;
      } else if (q.type === 'scale') {
        const max = parseInt(q.scaleMax || 5);
        html += `<div class="sp-sc-row" style="grid-template-columns: repeat(${max}, 1fr)">
          ${Array.from({length: max}, (_, i) => `<button class="sp-sc-b" data-val="${i+1}">${i+1}</button>`).join('')}
        </div>
        <div class="sp-sc-labs"><span>${q.labelL || ''}</span><span>${q.labelR || ''}</span></div>`;
      } else if (q.type === 'text') {
        html += `<textarea id="sp-i" class="sp-input" placeholder="${q.placeholder || '...'}"></textarea>`;
      }

      html += `</div><div class="sp-nav">`;
      if (currentStep > 0) html += `<button id="sp-back" class="sp-back-btn">${i18n.back}</button>`;
      
      // КНОПКА NEXT - ИЗНАЧАЛЬНО DISABLED
      html += `<button id="sp-next" class="sp-next-btn" disabled style="background:${theme}; color:${btnTxt}; border:${btnBorder}; opacity:0.5; cursor:not-allowed;">${isLast ? i18n.finish : i18n.next}</button></div>`;
      
      container.innerHTML = html;

      // ОБРАБОТЧИКИ
      container.querySelectorAll('.sp-e-btn, .sp-sc-b, .sp-o').forEach(b => {
        b.onclick = (e) => {
          // Skip кнопка
          if(b.classList.contains('sp-skip')) {
             processNext(q.label, "Skip");
             return;
          }

          e.preventDefault();
          const v = b.getAttribute('data-val');

          // CHECKBOX
          if (q.type === 'checkbox') {
             b.classList.toggle('is-s'); 
             if (b.classList.contains('is-s')) selected.push(v); else selected = selected.filter(i => i !== v);
             
             b.style.borderColor = b.classList.contains('is-s') ? theme : '#eee';
             const check = b.querySelector('.sp-c');
             if(check) {
               check.style.background = b.classList.contains('is-s') ? theme : 'transparent';
               check.style.borderColor = b.classList.contains('is-s') ? theme : '#ddd';
             }
          } else {
             // RADIO / EMOJI / SCALE (Single choice)
             selected = [v];
             
             // Сброс стилей у остальных
             container.querySelectorAll('.sp-e-btn, .sp-sc-b, .sp-o').forEach(el => {
               el.classList.remove('is-s');
               el.style.borderColor = '#eee';
               el.style.backgroundColor = '#fff'; 
               if(el.classList.contains('sp-sc-b')) el.style.color = '#333';
             });
             
             // Применение стиля к выбранному
             b.classList.add('is-s');
             if (!b.classList.contains('sp-e-btn')) { 
                b.style.borderColor = theme;
             }
             if (b.classList.contains('sp-sc-b')) {
                b.style.backgroundColor = theme;
                b.style.color = isWhite ? '#000' : '#fff';
             }
          }
          updateNextButton();
        };
      });

      // Слушатели ввода текста
      const txt = document.getElementById('sp-i');
      if(txt) txt.oninput = updateNextButton;
      
      const other = document.getElementById('sp-ot-i');
      if(other) other.oninput = updateNextButton;

      // Нажатие на NEXT
      container.querySelector('#sp-next').onclick = () => {
        let val = selected.join(', ');
        if (q.type === 'text') val = document.getElementById('sp-i').value;
        
        const otherVal = document.getElementById('sp-ot-i')?.value;
        if (otherVal) {
          val = val ? (val + ", " + otherVal) : otherVal;
        }
        
        processNext(q.label, val);
      };

      if (container.querySelector('#sp-back')) container.querySelector('#sp-back').onclick = () => { currentStep--; render(); };
      
      // Закрытие
      document.getElementById('sp-close').onclick = () => {
        localStorage.setItem(closedKey, 'true');
        document.getElementById('sp-widget').remove();
      };
    };

    const processNext = (key, val) => {
      answers[key] = val || "-";
      if (currentStep < questions.length - 1) { currentStep++; render(); } 
      else { finish(); }
    };

    const finish = async () => {
      document.getElementById('sp-card').innerHTML = `<p class="sp-thanks">${i18n.thanks}</p>`;
      try {
        await fetch(googleUrl, { method: 'POST', mode: 'no-cors',
          body: JSON.stringify({ respondentId, device: currentDevice, lang: lang, answer: JSON.stringify(answers), pageUrl: window.location.href })
        });
      } catch (e) {}
      localStorage.setItem(doneKey, 'true');
      setTimeout(() => document.getElementById('sp-widget').remove(), 3500);
    };

    const container = document.createElement('div');
    container.id = 'sp-widget'; container.className = 'sp-hidden';
    container.innerHTML = '<div id="sp-card" class="sp-card"></div>';
    document.body.appendChild(container);
    
    render();

    if (triggerType === 'purchase' && window.location.pathname.includes('/thank_you')) show();
    else if (triggerType === 'exit') {
       document.addEventListener('mouseleave', (e) => e.clientY <= 0 && show());
       let lastS = 0; window.addEventListener('scroll', () => {
         let st = window.pageYOffset; if (st < lastS && lastS - st > 40 && st > 100) show(); lastS = st;
       });
    } else if (triggerType === 'cart') {
      setInterval(async () => {
        try { const r = await fetch('/cart.js'); const cart = await r.json(); if (cart.item_count >= parseInt(tVal)) show(); } catch(e) {}
      }, 3000);
    } else { setTimeout(show, parseInt(tVal)*1000); }
  })();
</script>
<link rel="stylesheet" href="{{ 'widget.css' | asset_url }}">
{% schema %}
{ "name": "SheetPulse Widget", "target": "body", "settings": [] }
{% endschema %}
