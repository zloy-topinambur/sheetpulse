# Shopify API
# Получите эти значения в Shopify Partner Dashboard -> Apps -> [ваше приложение]
SHOPIFY_API_KEY=89faf3e331fad9beb46658573ca89bcc
SHOPIFY_API_SECRET=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

# App URL
# URL вашего приложения (для локальной разработки: http://localhost:3000)
APP_URL=https://sheetpulse.onrender.com
SHOPIFY_APP_URL=https://sheetpulse.onrender.com
HOST=https://sheetpulse.onrender.com

# Database
# PostgreSQL URL из Neon (https://neon.tech)
# Формат: postgresql://[user]:[password]@[endpoint]/[database]?sslmode=require
# ВАЖНО: Замените на реальный URL вашей базы данных!
# Пример: postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# Session Secret
# Секрет для подписи сессий (обязательно для production)
# Сгенерируйте с помощью: npm run generate-secret
SESSION_SECRET=your_session_secret_here_generate_random_string

# Scopes
# Разрешения, которые запрашивает ваше приложение
SCOPES=read_customers,write_customers,read_orders,read_products,write_products,write_script_tags

# Для локальной разработки раскомментируйте:
# APP_URL=http://localhost:3000
# SHOPIFY_APP_URL=http://localhost:3000
# HOST=localhost:3000
